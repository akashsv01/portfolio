# Web3Forms (https://web3forms.com) — contact form emails you when someone submits.
# Must be NEXT_PUBLIC_* so the browser can call Web3Forms directly (their free tier blocks server-only/proxy calls).
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# ── Portfolio chat (Groq — OpenAI-compatible API) — server-only, never NEXT_PUBLIC_* ──
# Create a key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional model override (default in code is llama-3.3-70b-versatile).
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: GitHub PAT for higher API rate limits when listing public repos (60/hr → 5k/hr).
# GITHUB_TOKEN=
