# Web3Forms (https://web3forms.com) — contact form emails you when someone submits.
# Must be NEXT_PUBLIC_* so the browser can call Web3Forms directly (their free tier blocks server-only/proxy calls).
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# ── Portfolio chat (Google AI Studio / Gemini API) — server-only, never NEXT_PUBLIC_* ──
# Create a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional model override (default in code is gemini-2.5-flash-lite).
# If you hit free-tier daily limits, try another model (e.g. gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: GitHub PAT for higher API rate limits when listing public repos (60/hr → 5k/hr).
# GITHUB_TOKEN=
